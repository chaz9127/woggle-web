PORT=3001
NODE_ENV=development
JWT_SECRET=changeme
# Directory for SQLite DB. In prod (Render), set to the mounted disk path (e.g. /var/data).
# Defaults to ../data relative to src/ when unset.
DATA_DIR=

# Session signing secret — generate a long random string for production.
SESSION_SECRET=dev-insecure-change-me

# Google OAuth — leave blank to disable the /api/auth/google route.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI in dev: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
